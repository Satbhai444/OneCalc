{
  "expo": {
    "name": "OneCalc",
    "slug": "OneCalc",
    "owner": "darshansatbhai",
    "sdkVersion": "52.0.0",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "onecalc",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/adaptive-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.darshansatbhai.OneCalc",
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d9dab27f-ec5d-447f-962a-a3bfdddb6729"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/d9dab27f-ec5d-447f-962a-a3bfdddb6729"
    }
  }
}
