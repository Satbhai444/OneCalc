{
  "expo": {
    "name": "OneCalc",
    "slug": "OneCalc",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "onecalc",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/adaptive-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "notification": {
        "icon": "./assets/images/adaptive-icon.png",
        "color": "#4A90D9"
      },
      "package": "com.darshansatbhai.OneCalc"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-font",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "OneCalcWidget",
              "label": "OneCalc Basic",
              "minWidth": "140dp",
              "minHeight": "110dp",
              "description": "Basic Calculator widget",
              "previewImage": "./assets/images/icon.png"
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d9dab27f-ec5d-447f-962a-a3bfdddb6729"
      }
    }
  }
}
